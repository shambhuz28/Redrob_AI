PORT=5000
FRONTEND_ORIGIN=http://localhost:5173,https://redrob-ai-frontend-tau.vercel.app

PYTHON_COMMAND=python3
PYTHON_SCRIPT=redrob_backend.py

# Optional. If redrob_backend.py always writes to a known CSV file, set it here.
# CSV_OUTPUT_PATH=ranked_candidates.csv

# Candidate matching can load ML models and call external APIs.
PYTHON_TIMEOUT_MS=300000

# Completed/failed jobs are kept in memory for 30 minutes by default.
JOB_TTL_MS=1800000
JOB_CLEANUP_INTERVAL_MS=300000

GEMINI_API_KEY=your-gemini-api-key
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=Candidates
EMBEDDING_MODEL=thenlper/gte-base
CANDIDATE_QUERY_LIMIT=150
HYDRATE_MISSING_SCORES=false
TOP_CANDIDATE_LIMIT=100
CANDIDATES_JSONL=../../dataset/info/candidates.jsonl
STRICT_HONEYPOT_FILTER=false
